{
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-extra-semi": "off"
  },
  "globals": {
    "io": "readonly",
    "mk": "writable",
    "Movement": "readonly"
  }
}
